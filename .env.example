# Supabase
VITE_SUPABASE_URL=your_supabase_url
VITE_SUPABASE_ANON_KEY=your_supabase_anon_key
SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_key

# NOWPayments (crypto payment provider)
NOWPAYMENTS_API_KEY=your_nowpayments_api_key

# Manual card payment (displayed to customer; set in Supabase secrets, not the bundle)
# These are read by the get-payment-details edge function only.
PAYMENT_CARD_NUMBER=your_card_number
PAYMENT_CARD_NAME=your_full_name
PAYMENT_BANK_NAME=MonoBank
